map $http_user_agent $blockedagent {
    default         0;

    # Generic scanner/automation keywords
    ~*bot           1;
    ~*crawler       1;
    ~*spider        1;
    ~*scanner       1;

    # Scripting languages and HTTP libs (not browser traffic)
    ~*perl          1;
    ~*python        1;
    ~*go-http        1;
    ~*axios         1;
    ~*wget          1;
    ~*curl          1;

    # Security / pentest tools (seen in logs or common in the wild)
    ~*ZAP           1;  # OWASP ZAP
    ~*dirbuster     1;
    ~*nikto         1;
    ~*sqlmap        1;
    ~*nmap          1;
    ~*masscan       1;
    ~*nuclei        1;
    ~*metasploit    1;
    ~*wpscan        1;
    ~*acunetix      1;
    ~*openvas       1;
    ~*nessus        1;
    ~*qualys        1;
    ~*havij         1;
    ~*w3af          1;
    ~*hydra         1;
    ~*burp          1;
    ~*pangolin      1;
    ~*paros         1;

    # Recon / internet-scanning services
    ~*CensysInspect  1;
    ~*Expanse        1;
    ~*zgrab          1;
    ~*masscan        1;
    ~*SSH            1;
    ~*ipip           1;
    ~*pdrlabs        1;
    ~*InternetMeasurement 1;
    ~*shodan         1;
    ~*l9explore      1;  # LeakIX scanner (seen in logs)
    ~*LeakIX         1;

    # UA strings seen in exploit scans against this server
    ~*Custom-AsyncHttpClient 1;  # PHP framework exploit sweep
    ~*QIHU           1;          # 360 Security (Chinese scanner browser)
}
